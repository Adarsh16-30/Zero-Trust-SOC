# Project Configuration
COMPOSE_PROJECT_NAME=zero-trust-soc

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_ADMIN_PASSWORD=ChangeMeStrongOpenSearchPassword!
OPENSEARCH_INITIAL_ADMIN_PASSWORD=${OPENSEARCH_ADMIN_PASSWORD}

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MinIO
MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=ChangeMeNow123!

# Grafana
GRAFANA_ADMIN_PASSWORD=YourGrafanaPass!

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=YourKeycloakAdminPass!
KEYCLOAK_DB_PASSWORD=YourKeycloakDbPass!
KEYCLOAK_GRAFANA_CLIENT_SECRET=ReplaceWithGrafanaClientSecret
KEYCLOAK_OPENSEARCH_CLIENT_SECRET=ReplaceWithOpenSearchClientSecret
KEYCLOAK_SHUFFLE_CLIENT_SECRET=ReplaceWithShuffleClientSecret
SOC_ANALYST_INITIAL_PASSWORD=ReplaceWithStrongAnalystPassword

# Neo4j
NEO4J_PASSWORD=YourNeo4jPass!

# Shuffle SOAR
SHUFFLE_ADMIN_USER=admin
SHUFFLE_ADMIN_PASSWORD=YourShufflePass!
SHUFFLE_ENCRYPTION_KEY=4f7bea9ced2dbcfafe1b7d4c82e1719fa2ace644147c8e9717763010836f43dd  

# SMTP Alerting (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_RECIPIENT=soc-alerts@yourdomain.com

# Shuffle SOAR Integration
SHUFFLE_WEBHOOK_URL=http://shuffle-frontend:3001/api/v1/hooks/YOUR_HOOK_ID
